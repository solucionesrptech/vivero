# URL del API Nest (sin barra final). En Vercel: URL pública del backend (https://...).
# El VALOR debe ser la URL real; nunca pongas el texto "NEXT_PUBLIC_PLANTALIA_API_URL" como valor.
# Recomendada:
NEXT_PUBLIC_PLANTALIA_API_URL=http://localhost:3101
# Alternativa soportada por el código (misma prioridad tras la de arriba):
# NEXT_PUBLIC_API_URL=http://localhost:3101
