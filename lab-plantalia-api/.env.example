# Copiar este archivo a .env en la raíz del API (no se sube a git).
# Ajustar usuario, contraseña y nombre de base si aplica.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/plantalia?schema=public"
PORT=3101

# JWT para rutas /admin/products (login en POST /admin/auth/login). Mínimo 8 caracteres.
# Obligatorio en producción (Render, etc.): sin esto el login responde 503 con mensaje explícito.
ADMIN_JWT_SECRET=cambiar-por-secreto-largo-en-desarrollo

# Primera vez (PostgreSQL en marcha, base "plantalia" creada):
#   npx prisma migrate deploy
#   npx prisma db seed
# Si POST /cart/items devuelve 500, casi siempre faltan tablas o el seed de productos.

# Producción: orígenes del front (coma). En desarrollo CORS refleja cualquier Origin.
# CORS_ORIGINS=https://tudominio.cl,https://www.tudominio.cl
