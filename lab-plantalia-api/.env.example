# Copiar este archivo a .env en la raíz del API (no se sube a git).
# Ajustar usuario, contraseña y nombre de base si aplica.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/plantalia?schema=public"
PORT=3101

# JWT para rutas /admin/products (login en POST /admin/auth/login). Mínimo 32 caracteres.
# Obligatorio en producción (Render, etc.): sin esto el login responde 503 con mensaje explícito.
ADMIN_JWT_SECRET=cambiar-por-secreto-largo-y-aleatorio-en-desarrollo

# Primera vez (PostgreSQL en marcha, base "plantalia" creada):
#   npx prisma migrate deploy
#
# Crear un admin (no borra datos existentes):
#   ADMIN_CREATE_EMAIL=otro@correo.cl ADMIN_CREATE_PASSWORD=ClaveSegura123 npm run prisma:create-admin
# Sin ambas variables el comando aborta por seguridad.
# Si POST /cart/items devuelve 500, casi siempre faltan tablas o datos de productos en la base.

# Producción: orígenes del front (coma). En producción es obligatoria.
# CORS_ORIGINS=https://tudominio.cl,https://www.tudominio.cl
#
# Si el API está detrás de un proxy/load balancer que sanea X-Forwarded-For,
# habilita esta variable para que el rate limit use la IP reenviada.
# RATE_LIMIT_TRUST_PROXY=true
#
# Swagger: en producción queda desactivado salvo que se habilite explícitamente.
# SWAGGER_ENABLED=true

# SMS a la tienda tras pedido cerrado (Twilio). V1: se envía tras checkout exitoso;
# con pasarela de pago, conviene mover el disparo a "pago confirmado" y revisar este hook.
# ORDER_SMS_ENABLED=true
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# STORE_NOTIFY_SMS_TO=56912345678
#
# Origen del SMS (uno u otro; si MG es válido, FROM se ignora):
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM_NUMBER=+15017122661
# TWILIO_FROM=+15017122661
#
# SMS al cliente cuando el pedido pasa a listo (admin, AWAITING_PREPARATION -> READY_*).
# Independiente de ORDER_SMS_ENABLED. Mismas credenciales Twilio; destino = teléfono del pedido.
# ORDER_READY_SMS_ENABLED=true
